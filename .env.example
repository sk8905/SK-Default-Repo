# Neon Postgres connection string (free tier). Get from https://console.neon.tech
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Anthropic API key. Get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Password to gate the app (chosen by you, any string)
APP_PASSWORD=change-me

# Secret token used by the daily cron endpoint (any long random string)
CRON_SECRET=change-me-too

# Public URL of the deployed app (used for absolute links). Optional.
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
